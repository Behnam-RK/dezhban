#!/usr/bin/env bash
# dezhban pre-commit hook: gofmt, vet, build, test, shellcheck.
# Enable once with:  git config core.hooksPath .githooks
set -euo pipefail

# Run from the repo root regardless of where git invoked us.
cd "$(git rev-parse --show-toplevel)"

fail() { printf '\033[31m✗ pre-commit: %s\033[0m\n' "$1" >&2; exit 1; }
ok()   { printf '\033[32m✓ %s\033[0m\n' "$1"; }
warn() { printf '\033[33m! %s\033[0m\n' "$1" >&2; }

# 1. Formatting — list any unformatted Go files instead of rewriting them.
# tools/ is in scope alongside cmd/ and internal/: it now carries real code
# (e.g. tools/relsign, the release-signing helper CI runs), not just taskmenu
# dev-scaffolding that used to be the only thing there.
unformatted="$(gofmt -l cmd/ internal/ tools/ 2>/dev/null || true)"
if [ -n "$unformatted" ]; then
	printf 'gofmt needs to run on:\n%s\n' "$unformatted" >&2
	fail "unformatted files (run: gofmt -w cmd/ internal/ tools/)"
fi
ok "gofmt"

# 2. Static analysis.
go vet ./... || fail "go vet failed"
ok "go vet"

# 3. Build (all platforms' shared code; host backend).
go build ./... || fail "go build failed"
ok "go build"

# 4. Tests.
go test ./... || fail "go test failed"
ok "go test"

# 5. Shell scripts — scripts/*.sh, packaging/macos/*.sh, packaging/linux/*.sh run
# as root on other people's machines (install.sh, upgrade helpers, the pkg
# postinstall/preremove hooks). Mirrors ci.yml's shellcheck job exactly (same
# -S warning threshold), so a local commit can't drift from what CI will
# enforce. Soft-skips if shellcheck isn't installed locally — CI is still the
# real gate, this is just an earlier catch.
if command -v shellcheck >/dev/null 2>&1; then
	shellcheck -S warning scripts/*.sh packaging/macos/*.sh packaging/linux/*.sh || fail "shellcheck failed"
	ok "shellcheck"
else
	warn "shellcheck not installed — skipping locally (CI still runs it)"
fi

printf '\033[32mpre-commit: all checks passed\033[0m\n'
