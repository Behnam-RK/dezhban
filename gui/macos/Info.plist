<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleName</key>
	<string>Dezhban</string>
	<key>CFBundleDisplayName</key>
	<string>Dezhban</string>
	<key>CFBundleIdentifier</key>
	<string>com.behnam-rk.dezhban.app</string>
	<key>CFBundleExecutable</key>
	<string>DezhbanMenu</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<!-- Dev default, overwritten by build-app.sh for a release build. 0.0.0 (not a
	     plausible-looking 0.1.0) so an unstamped build is visibly unstamped and
	     never masquerades as a release. -->
	<key>CFBundleShortVersionString</key>
	<string>0.0.0</string>
	<key>CFBundleVersion</key>
	<string>0.0.0</string>
	<key>LSMinimumSystemVersion</key>
	<string>13.0</string>
	<!-- Regular app, not a menubar agent: the Dock tile doubles as a state
	     display (AppDelegate swaps the Dock icon to match the enforcement
	     posture), so the app must be visible in the Dock. -->
	<key>LSUIElement</key>
	<false/>
	<key>NSHumanReadableCopyright</key>
	<string>dezhban network kill switch</string>
</dict>
</plist>
